# ── CheckTrack environment variables ──────────────────────────────
# Copy to `.env.local` and fill in. `.env.local` is git-ignored (secrets).

# Public base URL of the app (used to build remote-signing links).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Your company name — appears in the signing message and the signing page.
COMPANY_NAME=

# Dev mode: when "true", Google Sheets/Drive calls are stubbed with an
# in-memory store so the app runs with zero Google setup. Set to "false"
# (or remove) once the Google credentials below are configured.
CHECKTRACK_DEV_MODE=true

# ── Google OAuth (company account, offline access for Drive + Sheets) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# One-time obtained refresh token for the company account that owns the
# Drive folder + Sheet. Server-side only.
GOOGLE_REFRESH_TOKEN=

# ── Google resources ──
# Spreadsheet ID of the central database (the part of the URL after /d/).
GOOGLE_SHEET_ID=
# Tab name inside the spreadsheet.
GOOGLE_SHEET_TAB=Checks
# Drive folder ID where signed check PDFs are archived.
GOOGLE_DRIVE_FOLDER_ID=

# ── Tokens (remote signing, Phase 4) ──
# Secret used to sign one-time signing tokens (use a long random string).
TOKEN_SIGNING_SECRET=

# ── Auth (NextAuth / Google login for screens 1–2) ──
# Random secret for session encryption (generate: `openssl rand -base64 32`).
AUTH_SECRET=
# Comma-separated list of emails allowed into screens 1–2 (personal Gmail).
AUTH_ALLOWED_EMAILS=
# Optional: restrict Google sign-in to a Workspace domain (e.g. example.com).
AUTH_ALLOWED_DOMAIN=
# NOTE: auth turns on automatically when GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET
# are set. Add the OAuth redirect URI in Google Cloud:
#   <NEXT_PUBLIC_BASE_URL>/api/auth/callback/google

# ── PDF rendering (Puppeteer) ──
# Path to a Chromium-based browser (Chrome/Edge). puppeteer-core drives the
# system browser instead of downloading Chromium. Auto-detected if omitted.
PUPPETEER_EXECUTABLE_PATH=

# ── OCR (Phase 6, cost-gated) ──
GOOGLE_VISION_API_KEY=
